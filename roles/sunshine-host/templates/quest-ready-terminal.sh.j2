#!/usr/bin/env bash
set -euo pipefail

runtime_dir="{{ sunshine_host_state_dir }}"
printf '\033]2;%s\007' "Sunshine Host"
clear 2>/dev/null || true

cat <<EOF
Sunshine host is ready.

Moonlight is connected to the headless Sway display.
Launch "eaadwig", "morrowind", "quake3", "tmux", "rocknix", or "steam" from Moonlight.

Runtime logs:
  $runtime_dir/eaadwig.log
  $runtime_dir/morrowind.log
  $runtime_dir/quake3.log
  $runtime_dir/tmux.log
  $runtime_dir/rocknix.log
  $runtime_dir/steam.log

EOF

for log in \
  "$runtime_dir/eaadwig.log" \
  "$runtime_dir/morrowind.log" \
  "$runtime_dir/quake3.log" \
  "$runtime_dir/tmux.log" \
  "$runtime_dir/rocknix.log" \
  "$runtime_dir/steam.log"; do
  if [ -s "$log" ]; then
    printf 'Last lines from %s:\n' "$log"
    tail -n 12 "$log" || true
    printf '\n'
  fi
done

exec "${SHELL:-/usr/bin/bash}"
